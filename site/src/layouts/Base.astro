---
import LangToggle from "../components/LangToggle.astro";
import { UI, type Locale } from "../i18n/ui";

interface Props {
  title: string;
  lang?: Locale;
  /** 不含 locale 前綴的純路徑,給語言切換用。 */
  path?: string;
}
const { title, lang = "zh", path = "/" } = Astro.props;
const t = UI[lang];
const base = lang === "en" ? "/en" : "";
// 訪客埋點 beacon 的 API 網域(部署時 PUBLIC_API_URL 注入,本機留空=同源)。
const apiUrl = import.meta.env.PUBLIC_API_URL ?? "";
---

<!doctype html>
<html lang={lang === "en" ? "en" : "zh-Hant"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&family=Noto+Sans+TC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg: #faf9f6;
        --bg-elev: #ffffff;
        --ink: #18181b;
        --ink-soft: #3f3f46;
        --muted: #6b7280;
        --line: #e7e4dd;
        --accent: #2347d6;
        --accent-soft: #eef1fd;
        --sans: "Hanken Grotesk", "Noto Sans TC", system-ui, sans-serif;
        --mono: "Space Mono", "Noto Sans TC", ui-monospace, monospace;
        --maxw: 760px;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: var(--sans);
        font-size: 16px;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; text-underline-offset: 3px; }

      ::selection { background: var(--accent-soft); }

      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 3px;
      }

      .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 1.4rem; }

      /* 頂列 */
      .site-head {
        border-bottom: 1px solid var(--line);
        background: color-mix(in srgb, var(--bg) 85%, transparent);
        backdrop-filter: saturate(1.1) blur(6px);
        position: sticky;
        top: 0;
        z-index: 10;
      }
      .site-head .row {
        display: flex;
        align-items: center;
        gap: 1rem;
        height: 56px;
      }
      .wordmark {
        font-weight: 800;
        letter-spacing: -0.01em;
        color: var(--ink);
        font-size: 1rem;
      }
      .wordmark:hover { text-decoration: none; }
      .wordmark .tick { color: var(--accent); }
      .site-head nav.main {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 1.3rem;
        font-size: 0.9rem;
      }
      .site-head nav.main a { color: var(--ink-soft); }
      .site-head nav.main a:hover { color: var(--accent); text-decoration: none; }

      .site-foot {
        border-top: 1px solid var(--line);
        margin-top: 5rem;
        padding: 2rem 0 3rem;
        color: var(--muted);
        font-family: var(--mono);
        font-size: 0.76rem;
      }
      .site-foot .oss { margin-top: 0.4rem; }

      h1, h2, h3 { line-height: 1.2; letter-spacing: -0.015em; }

      .eyebrow {
        font-family: var(--mono);
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .reveal {
        opacity: 0;
        transform: translateY(10px);
        animation: rise 0.5s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
      }
      @keyframes rise { to { opacity: 1; transform: none; } }
      @media (prefers-reduced-motion: reduce) {
        .reveal { animation: none; opacity: 1; transform: none; }
        html { scroll-behavior: auto; }
      }

      /* 列印 / 存成 PDF:去掉導覽列、頁尾、PDF 按鈕,展開動畫,印滿背景 */
      @media print {
        .site-head, .site-foot, .pdf-btn, .email .copy { display: none !important; }
        .reveal { opacity: 1 !important; transform: none !important; }
        body { background: #fff; }
        main { padding-top: 0.5rem; }
        a { color: var(--ink); }
        .card, .metric, .console, .fig img { box-shadow: none !important; }
        .card, .xp, .metric, .fig { break-inside: avoid; }
        h2 { break-after: avoid; }
        * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      }
    </style>
  </head>
  <body>
    <header class="site-head">
      <div class="wrap row">
        <a href={base + "/"} class="wordmark">Derek Chen<span class="tick">.</span></a>
        <nav class="main">
          <a href={base + "/#experience"}>{t.nav_experience}</a>
          <a href={base + "/#projects"}>{t.nav_projects}</a>
          <a href={base + "/ask"}>{t.nav_ask}</a>
          <LangToggle lang={lang} path={path} />
        </nav>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="site-foot">
      <div class="wrap">
        <div>© 2026 Derek Chen · built with Astro on Cloudflare</div>
        <div class="oss">
          {t.footer_oss}
          <a href="https://github.com/smallkill/devbox" target="_blank" rel="noopener noreferrer">github.com/smallkill/devbox ↗</a>
        </div>
      </div>
    </footer>
    <script define:vars={{ apiUrl }}>
      // 訪客埋點:fire-and-forget,失敗無感,絕不阻擋頁面。
      try {
        fetch(`${apiUrl}/api/visit?path=` + encodeURIComponent(location.pathname), {
          method: "GET", mode: "no-cors", keepalive: true,
        }).catch(() => {});
      } catch { /* ignore */ }
    </script>
  </body>
</html>
