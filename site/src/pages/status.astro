---
// API 網域於部署時用環境變數 PUBLIC_API_URL 注入(本機留空 → 同源)。
const apiUrl = import.meta.env.PUBLIC_API_URL ?? "";
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>devbox — 系統即時狀態</title>
    <style>
      body {
        font-family: ui-sans-serif, system-ui, sans-serif;
        max-width: 760px; margin: 0 auto; padding: 3rem 1.5rem;
      }
      .grid { display: flex; gap: 1rem; flex-wrap: wrap; }
      .card {
        flex: 1; min-width: 200px;
        border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.5rem;
      }
      .metric { font-size: 2.5rem; font-weight: 700; }
      .label { color: #6b7280; }
      table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
      th, td { text-align: left; padding: 0.6rem 0.4rem; border-bottom: 1px solid #f0f0f0; }
      th { color: #6b7280; font-weight: 600; font-size: 0.85rem; }
      code { background: #f3f4f6; padding: 0.1rem 0.4rem; border-radius: 4px; }
      a { font-weight: 600; }
      .muted { color: #9ca3af; }
    </style>
  </head>
  <body>
    <p><a href="/">← 回履歷</a></p>
    <h1>devbox 系統狀態</h1>

    <div class="grid">
      <div class="card">
        <div class="metric" id="links">…</div>
        <div class="label">短網址連結總數</div>
      </div>
      <div class="card">
        <div class="metric" id="clicks">…</div>
        <div class="label">近 24 小時點擊</div>
      </div>
    </div>

    <h2>Top 連結(近 24h)</h2>
    <table>
      <thead><tr><th>Slug</th><th>點擊</th></tr></thead>
      <tbody id="top"><tr><td colspan="2" class="muted">載入中…</td></tr></tbody>
    </table>

    <script define:vars={{ apiUrl }}>
      fetch(`${apiUrl}/api/stats`)
        .then((r) => r.json())
        .then((d) => {
          document.getElementById("links").textContent = d.links ?? "—";
          document.getElementById("clicks").textContent =
            d.clicks24h ?? "—";
          const top = document.getElementById("top");
          if (Array.isArray(d.topLinks) && d.topLinks.length) {
            // 用 DOM API + textContent,自動轉義、免 XSS。
            top.replaceChildren(
              ...d.topLinks.map((l) => {
                const tr = document.createElement("tr");
                const tdSlug = document.createElement("td");
                const code = document.createElement("code");
                code.textContent = l.slug;
                tdSlug.append(code);
                const tdClicks = document.createElement("td");
                tdClicks.textContent = String(l.clicks);
                tr.append(tdSlug, tdClicks);
                return tr;
              }),
            );
          } else {
            const tr = document.createElement("tr");
            const td = document.createElement("td");
            td.colSpan = 2;
            td.className = "muted";
            td.textContent = "尚無點擊資料";
            tr.append(td);
            top.replaceChildren(tr);
          }
        })
        .catch(() => {
          document.getElementById("links").textContent = "離線";
          document.getElementById("clicks").textContent = "離線";
        });
    </script>
  </body>
</html>
