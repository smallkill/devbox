---
import Base from "../layouts/Base.astro";

// Cloudflare Pages:dist 根目錄存在 404.html 時,未知路徑會回此頁(HTTP 404),
// 取代預設的「SPA fallback 回首頁 200」(soft-404 對 SEO 不利)。
---

<Base title="404 — Derek Chen" lang="zh" path="/">
  <section class="nf">
    <span class="eyebrow">// 404</span>
    <h1>找不到這一頁</h1>
    <p class="msg">
      這個網址不存在或已被移動。<br />
      The page you're looking for doesn't exist or has moved.
    </p>
    <p class="nav-links">
      <a href="/">← 回首頁 / Home</a>
      <span class="sep">·</span>
      <a href="/ask">AI 履歷問答 / Ask</a>
    </p>
  </section>
</Base>

<style>
  .nf { padding: 4rem 0 2rem; }
  .nf h1 {
    font-size: clamp(2rem, 7vw, 3rem);
    font-weight: 800;
    margin: 0.5rem 0 0.8rem;
  }
  .msg { color: var(--ink-soft); line-height: 1.7; margin: 0 0 1.4rem; }
  .nav-links { font-family: var(--mono); font-size: 0.9rem; }
  .nav-links .sep { margin: 0 0.6rem; color: var(--muted); }
</style>
