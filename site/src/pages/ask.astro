---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import AskChat from "../components/AskChat.astro";
import AskHardening from "../components/AskHardening.astro";
import { UI } from "../i18n/ui";

// content collection 條目 id 形如 "zh/moxa-cicd";取乾淨的 project slug。
const all = await getCollection("projects");
const projectSlugs = [
  ...new Set(all.map((e) => e.id.replace(/^(zh|en)\//, ""))),
];
---

<Base title="問我關於 Derek 的事 — devbox" lang="zh" path="/ask" description={UI.zh.ask_intro}>
  <AskChat lang="zh" projectSlugs={projectSlugs} />
  <AskHardening lang="zh" />
</Base>
