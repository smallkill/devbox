---
import Base from "../layouts/Base.astro";

const name = "DEREK CHEN";
const role = "Software / DevOps Engineer";
const summary =
  "自架生產級 SaaS:從 git push 到 CI/CD 自動部署到即時監控,全棧打通。以 Cloudflare Workers + Pages 為核心,Infrastructure-as-Code 與可觀測性優先。";

const stack = [
  "TypeScript",
  "Cloudflare Workers",
  "Pages · D1 · Analytics Engine",
  "GitHub Actions CI/CD",
  "Terraform / IaC",
  "Observability",
  "Test-Driven Development",
];

const stats = [
  { k: "deploy", v: "git push", note: "自動化" },
  { k: "tests", v: "23", note: "TDD 全綠" },
  { k: "stack", v: "100%", note: "Cloudflare" },
];

const links = [
  { cmd: "open", label: "github.com/smallkill", href: "https://github.com/smallkill" },
  { cmd: "exec", label: "./status — 即時監控儀表板", href: "/status" },
];
---

<Base title="derek — software / devops engineer">
  <section class="hero reveal" style="animation-delay: 80ms">
    <span class="label">// engineer profile</span>
    <h1 class="name">{name}<span class="blink"></span></h1>
    <p class="role">{role}</p>
  </section>

  <p class="summary reveal" style="animation-delay: 180ms">{summary}</p>

  <div class="stats reveal" style="animation-delay: 260ms">
    {
      stats.map((s) => (
        <div class="stat">
          <div class="stat-v">{s.v}</div>
          <div class="stat-k">{s.k}</div>
          <div class="stat-note">{s.note}</div>
        </div>
      ))
    }
  </div>

  <section class="block reveal" style="animation-delay: 340ms">
    <span class="label">// featured build</span>
    <a class="feature" href="/status">
      <div class="feature-head">
        <span class="feature-name">devbox</span>
        <span class="live"><span class="pulse"></span>LIVE</span>
      </div>
      <p class="feature-desc">
        短網址 SaaS — Workers + D1 + Analytics Engine,Cron 告警,
        GitHub Actions push 自動部署,附即時點擊監控儀表板。
      </p>
      <span class="feature-go">cat ./status →</span>
    </a>
  </section>

  <section class="block reveal" style="animation-delay: 420ms">
    <span class="label">// stack --list</span>
    <ul class="chips">
      {stack.map((s) => <li>{s}</li>)}
    </ul>
  </section>

  <section class="block reveal" style="animation-delay: 500ms">
    <span class="label">// links</span>
    <div class="links">
      {
        links.map((l) => (
          <a class="lnk" href={l.href}>
            <span class="prompt">$</span>
            <span class="lnk-cmd">{l.cmd}</span>
            <span class="lnk-label">{l.label}</span>
          </a>
        ))
      }
    </div>
  </section>

  <style>
    .hero { margin-bottom: 1.6rem; }
    .name {
      font-family: var(--display);
      font-weight: 700;
      font-size: clamp(2.6rem, 9vw, 5rem);
      line-height: 0.98;
      letter-spacing: -0.02em;
      margin: 0.4rem 0 0.5rem;
      color: #f3faf5;
      text-shadow: 0 0 28px rgba(74, 222, 128, 0.25);
    }
    .role {
      font-size: 0.95rem;
      letter-spacing: 0.06em;
      color: var(--accent);
      margin: 0;
    }
    .summary {
      max-width: 60ch;
      color: var(--fg);
      margin: 1.4rem 0 2.4rem;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--line-strong);
      border: 1px solid var(--line-strong);
      border-radius: 10px;
      overflow: hidden;
      margin-bottom: 3rem;
    }
    .stat { background: var(--bg-elev); padding: 1.1rem 1.2rem; }
    .stat-v {
      font-family: var(--display);
      font-size: 1.7rem;
      font-weight: 700;
      color: var(--accent);
    }
    .stat-k { font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--fg); margin-top: 0.2rem; }
    .stat-note { font-size: 0.7rem; color: var(--muted); }

    .block { margin-bottom: 3rem; }
    .block .label { display: block; margin-bottom: 0.9rem; }

    .feature {
      display: block;
      background: linear-gradient(180deg, rgba(74,222,128,0.05), transparent), var(--bg-elev);
      border: 1px solid var(--line-strong);
      border-radius: 12px;
      padding: 1.4rem 1.5rem;
      transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
    }
    .feature:hover {
      border-color: var(--accent-dim);
      transform: translateY(-3px);
      box-shadow: 0 14px 40px -20px rgba(74, 222, 128, 0.5);
    }
    .feature-head { display: flex; align-items: center; gap: 0.8rem; }
    .feature-name {
      font-family: var(--display);
      font-size: 1.5rem;
      font-weight: 700;
      color: #f3faf5;
    }
    .live {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-size: 0.66rem; letter-spacing: 0.16em; color: var(--accent);
      border: 1px solid var(--accent-dim); border-radius: 999px;
      padding: 0.15rem 0.55rem;
    }
    .pulse {
      width: 7px; height: 7px; border-radius: 50%; background: var(--accent);
      box-shadow: 0 0 0 0 rgba(74,222,128,0.6); animation: pulse 1.8s infinite;
    }
    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(74,222,128,0.55); }
      70% { box-shadow: 0 0 0 7px rgba(74,222,128,0); }
      100% { box-shadow: 0 0 0 0 rgba(74,222,128,0); }
    }
    .feature-desc { color: var(--fg); margin: 0.7rem 0 0.9rem; font-size: 0.92rem; }
    .feature-go { font-size: 0.8rem; color: var(--accent); }

    .chips { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.6rem; }
    .chips li {
      font-size: 0.82rem;
      color: var(--fg);
      border: 1px solid var(--line-strong);
      border-radius: 6px;
      padding: 0.35rem 0.75rem;
      background: var(--bg-elev);
      transition: border-color 0.2s, color 0.2s, box-shadow 0.2s;
    }
    .chips li::before { content: "› "; color: var(--accent-dim); }
    .chips li:hover {
      color: #f3faf5;
      border-color: var(--accent-dim);
      box-shadow: inset 0 0 18px -10px rgba(74,222,128,0.6);
    }

    .links { display: flex; flex-direction: column; gap: 0.5rem; }
    .lnk {
      display: flex; align-items: center; gap: 0.7rem;
      padding: 0.7rem 0.9rem;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--bg-elev);
      color: var(--fg);
      transition: border-color 0.2s, transform 0.2s;
    }
    .lnk:hover { border-color: var(--accent-dim); transform: translateX(4px); }
    .prompt { color: var(--accent); }
    .lnk-cmd { color: var(--cyan); }
    .lnk-label { color: var(--fg); }
  </style>
</Base>
