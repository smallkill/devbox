---
import { getCollection } from "astro:content";
import { resolveLocalized } from "../i18n/content";
import { UI, type Locale } from "../i18n/ui";
import { RESUME } from "../lib/resume";
import ProjectCard from "./ProjectCard.astro";
import ExperienceItem from "./ExperienceItem.astro";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = UI[lang];
const base = lang === "en" ? "/en" : "";

const projectEntries = await getCollection("projects");
const experienceEntries = await getCollection("experience");

const projects = resolveLocalized(projectEntries, lang)
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const experience = resolveLocalized(experienceEntries, lang).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section class="hero reveal">
  <div class="hero-top">
    <img class="avatar" src={RESUME.avatar} alt={RESUME.name} width="84" height="84" />
    <div>
      <span class="eyebrow">// {t.role}</span>
      <h1>{RESUME.name}</h1>
    </div>
  </div>
  <p class="intro">{RESUME.intro[lang]}</p>

  <ul class="traits">
    {RESUME.traits[lang].map((tr) => <li>{tr}</li>)}
  </ul>

  <div class="email">
    <span class="addr">{RESUME.email}</span>
    <button
      class="copy"
      type="button"
      data-copy={RESUME.email}
      data-copied={t.copied}
      aria-label={t.copy_aria}
    >
      {t.copy}
    </button>
  </div>

  <nav class="links" aria-label="profile links">
    {RESUME.links.map((l) => (
      <a href={l.href} target={l.href.startsWith("http") ? "_blank" : null} rel="noopener noreferrer">
        {l.label} ↗
      </a>
    ))}
    <button class="pdf-btn" type="button" onclick="window.print()">{t.download_pdf} ↓</button>
  </nav>

  <script>
    document.querySelectorAll("[data-copy]").forEach((btn) => {
      const el = btn as HTMLElement;
      const original = btn.textContent; // 一次捕捉原始標籤,避免連點卡住
      let timer: ReturnType<typeof setTimeout>;
      btn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(el.dataset.copy ?? "");
          btn.textContent = el.dataset.copied ?? "✓";
          clearTimeout(timer);
          timer = setTimeout(() => { btn.textContent = original; }, 1500);
        } catch {
          /* clipboard 不可用時,使用者仍可手動選取地址 */
        }
      });
    });
  </script>
</section>

<section class="block reveal" style="animation-delay: 90ms">
  <h2>{t.experience}</h2>
  {experience.length === 0 ? (
    <p class="soon">{t.experience_soon}</p>
  ) : (
    experience.map((x) => (
      <ExperienceItem
        org={x.data.org}
        role={x.data.role}
        period={x.data.period}
        location={x.data.location}
        logo={x.data.logo}
        tech={x.data.tech}
        highlights={x.data.highlights}
      />
    ))
  )}
</section>

<section class="block reveal" style="animation-delay: 150ms">
  <h2>{t.skills}</h2>
  <div class="skills">
    {RESUME.skills.map((g) => (
      <div class="sgroup">
        <div class="sgroup-name">{g.group}</div>
        <ul>
          {g.items.map((it) => (
            <li>{it}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<section id="projects" class="block reveal" style="animation-delay: 210ms">
  <h2>{t.projects}</h2>
  <div class="grid">
    {projects.map((p) => (
      <ProjectCard
        href={`${base}/projects/${p.slug}`}
        title={p.data.title}
        role={p.data.role}
        period={p.data.period}
        tech={p.data.tech}
        cover={p.data.cover}
        fallbackLabel={p.fallback ? t.fallback : undefined}
      />
    ))}
  </div>
</section>

<style>
  .hero { padding: 2.5rem 0 1rem; }
  .hero-top { display: flex; align-items: center; gap: 1.1rem; margin-bottom: 0.9rem; }
  .avatar {
    width: 84px; height: 84px; border-radius: 50%; object-fit: cover;
    border: 1px solid var(--line); flex-shrink: 0;
    box-shadow: 0 4px 16px -10px rgba(24, 24, 27, 0.4);
  }
  .hero-top h1 { font-size: clamp(2.2rem, 7vw, 3.2rem); font-weight: 800; margin: 0.3rem 0 0; }
  .hero h1 { font-size: clamp(2.2rem, 7vw, 3.2rem); font-weight: 800; margin: 0.5rem 0 0.7rem; }
  .intro { font-size: 1.1rem; color: var(--ink-soft); max-width: 56ch; margin: 0 0 1.2rem; }
  .traits {
    list-style: none; margin: 0 0 1.4rem; padding: 0;
    display: flex; flex-wrap: wrap; gap: 0.5rem;
  }
  .traits li {
    font-size: 0.84rem; color: var(--ink-soft);
    background: var(--accent-soft); border: 1px solid color-mix(in srgb, var(--accent) 18%, var(--line));
    border-radius: 999px; padding: 0.3rem 0.8rem;
  }
  .traits li::before { content: "✦ "; color: var(--accent); }

  .email {
    display: flex; align-items: center; gap: 0.6rem;
    font-family: var(--mono); font-size: 0.9rem; margin-bottom: 1rem;
  }
  .email .addr {
    color: var(--ink); user-select: all;
    background: var(--bg-elev); border: 1px solid var(--line);
    border-radius: 6px; padding: 0.25rem 0.6rem;
  }
  .email .copy {
    font-family: var(--mono); font-size: 0.75rem; cursor: pointer;
    color: var(--accent); background: transparent;
    border: 1px solid var(--line); border-radius: 6px; padding: 0.25rem 0.55rem;
  }
  .email .copy:hover { border-color: var(--accent-dim, var(--accent)); background: var(--accent-soft); }

  .links { display: flex; flex-wrap: wrap; align-items: center; gap: 1.1rem; font-family: var(--mono); font-size: 0.85rem; }
  .pdf-btn {
    font-family: var(--mono); font-size: 0.82rem; cursor: pointer;
    color: var(--accent); background: var(--accent-soft);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
    border-radius: 6px; padding: 0.25rem 0.7rem;
  }
  .pdf-btn:hover { background: var(--accent); color: #fff; }

  .block { padding: 1.8rem 0; }
  .block h2 {
    font-size: 0.95rem;
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.5rem;
    margin: 0 0 0.6rem;
  }
  .soon { color: var(--muted); font-style: italic; }

  .skills { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
  @media (max-width: 560px) { .skills { grid-template-columns: 1fr; } }
  .sgroup-name { font-family: var(--mono); font-size: 0.75rem; color: var(--accent); margin-bottom: 0.4rem; }
  .sgroup ul { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .sgroup li {
    font-size: 0.85rem; color: var(--ink-soft);
    background: var(--bg-elev); border: 1px solid var(--line);
    border-radius: 6px; padding: 0.2rem 0.6rem;
  }

  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem; }
  @media (max-width: 620px) { .grid { grid-template-columns: 1fr; } }
</style>
