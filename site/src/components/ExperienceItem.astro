---
interface Props {
  org: string;
  role: string;
  period: string;
  location?: string;
  tech?: string[];
  highlights?: string[];
}
const { org, role, period, location, tech = [], highlights = [] } = Astro.props;
---

<article class="xp">
  <div class="period">
    {period}
    {location && <span class="loc">{location}</span>}
  </div>
  <div class="detail">
    <h3>{role} <span class="at">·</span> <span class="org">{org}</span></h3>
    {highlights.length > 0 && (
      <ul class="hl">
        {highlights.map((h) => (
          <li>{h}</li>
        ))}
      </ul>
    )}
    {tech.length > 0 && (
      <ul class="tech">
        {tech.map((x) => (
          <li>{x}</li>
        ))}
      </ul>
    )}
  </div>
</article>

<style>
  .xp {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1.2rem;
    padding: 1.4rem 0;
    border-top: 1px solid var(--line);
  }
  @media (max-width: 560px) {
    .xp { grid-template-columns: 1fr; gap: 0.4rem; }
  }
  .period {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--muted);
    padding-top: 0.2rem;
  }
  .loc { display: block; margin-top: 0.2rem; color: var(--line); }
  @media (max-width: 560px) { .loc { display: inline; margin-left: 0.5rem; } }
  .detail h3 { margin: 0 0 0.5rem; font-size: 1.05rem; color: var(--ink); }
  .detail .at { color: var(--line); }
  .detail .org { color: var(--accent); }
  .hl { margin: 0 0 0.7rem; padding-left: 1.1rem; color: var(--ink-soft); font-size: 0.93rem; }
  .hl li { margin: 0.25rem 0; }
  .hl li::marker { color: var(--accent); }
  .tech {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tech li {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--ink-soft);
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 0.15rem 0.45rem;
  }
</style>
