---
interface Props {
  src: string;
  caption?: string;
  alt?: string;
}
const { src, caption, alt } = Astro.props;
---

<figure class="fig">
  <img src={src} alt={alt ?? caption ?? ""} loading="lazy" decoding="async" />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .fig { margin: 1.6rem 0; }
  .fig img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--line);
    border-radius: 10px;
    box-shadow: 0 1px 2px rgba(24, 24, 27, 0.04), 0 8px 24px -16px rgba(24, 24, 27, 0.25);
    background: var(--bg-elev);
  }
  figcaption {
    margin-top: 0.6rem;
    font-family: var(--mono);
    font-size: 0.74rem;
    color: var(--muted);
  }
</style>
