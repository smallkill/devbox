---
import { UI, type Locale } from "../i18n/ui";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = UI[lang];
const base = lang === "en" ? "/en" : "";
// API 網域於部署時用環境變數 PUBLIC_API_URL 注入(本機留空 → 同源)。
const apiUrl = import.meta.env.PUBLIC_API_URL ?? "";
// 傳給 client script 的本地化字串。
const txt = {
  noClicks: t.st_no_clicks,
  lastSync: t.st_last_sync,
  connFailed: t.st_conn_failed,
};
---

<section class="head">
  <div>
    <span class="eyebrow">{t.st_eyebrow}</span>
    <h1>{t.st_title}</h1>
    <p class="sub">{t.st_intro}</p>
    <a class="see" href={`${base}/projects/devbox`}>{t.st_see_project}</a>
  </div>
  <div class="livebox" aria-live="polite">
    <span class="live" id="live"><span class="pulse"></span><span id="live-text">LIVE</span></span>
    <span class="sync" id="sync">{t.st_syncing}</span>
  </div>
</section>

<div class="grid">
  <div class="metric">
    <span class="m-label">{t.st_short_links}</span>
    <span class="m-val" id="links" data-v="0">—</span>
    <span class="m-unit">links total</span>
  </div>
  <div class="metric accent">
    <span class="m-label">{t.st_clicks24h}</span>
    <span class="m-val" id="clicks" data-v="0">—</span>
    <span class="m-unit">clicks / 24h</span>
  </div>
</div>

<section class="topwrap">
  <h2>{t.st_top}</h2>
  <div class="console">
    <div class="console-bar"><code>SELECT slug, count() ORDER BY clicks DESC</code></div>
    <table>
      <thead><tr><th>#</th><th>slug</th><th>clicks</th><th>share</th></tr></thead>
      <tbody id="top"><tr><td colspan="4" class="muted">{t.st_querying}</td></tr></tbody>
    </table>
  </div>
</section>

<style>
  .head { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap; padding: 1.6rem 0 0.5rem; }
  .head h1 { font-size: clamp(1.8rem, 6vw, 2.6rem); font-weight: 800; margin: 0.4rem 0 0.5rem; }
  .head .sub { color: var(--ink-soft); margin: 0 0 0.6rem; max-width: 54ch; font-size: 0.96rem; line-height: 1.6; }
  .see { font-family: var(--mono); font-size: 0.82rem; }
  .livebox { display: flex; flex-direction: column; align-items: flex-end; gap: 0.35rem; }
  .live { display: inline-flex; align-items: center; gap: 0.45rem; font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.06em; color: #15803d; border: 1px solid #bbf7d0; background: #f0fdf4; border-radius: 999px; padding: 0.2rem 0.6rem; }
  .live.off { color: #b91c1c; border-color: #fecaca; background: #fef2f2; }
  .live.off .pulse { background: #ef4444; animation: none; }
  .pulse { width: 7px; height: 7px; border-radius: 50%; background: #22c55e; animation: pulse 1.8s infinite; }
  @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(34,197,94,0.5);} 70% { box-shadow: 0 0 0 6px rgba(34,197,94,0);} 100% { box-shadow: 0 0 0 0 rgba(34,197,94,0);} }
  .sync { font-family: var(--mono); font-size: 0.68rem; color: var(--muted); }

  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1.5rem 0 2.5rem; }
  @media (max-width: 540px) { .grid { grid-template-columns: 1fr; } }
  .metric { position: relative; background: var(--bg-elev); border: 1px solid var(--line); border-radius: 12px; padding: 1.3rem 1.4rem; overflow: hidden; }
  .metric::after { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--line); }
  .metric.accent::after { background: var(--accent); }
  .m-label { font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.04em; color: var(--muted); }
  .m-val { display: block; font-weight: 800; font-size: clamp(2.4rem, 8vw, 3.2rem); line-height: 1.05; color: var(--ink); font-variant-numeric: tabular-nums; margin: 0.25rem 0 0.1rem; }
  .metric.accent .m-val { color: var(--accent); }
  .m-unit { font-family: var(--mono); font-size: 0.7rem; color: var(--muted); }

  .topwrap h2 { font-family: var(--mono); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin: 0 0 0.7rem; }
  .console { border: 1px solid var(--line); border-radius: 12px; overflow: hidden; background: var(--bg-elev); }
  .console-bar { padding: 0.6rem 0.9rem; border-bottom: 1px solid var(--line); background: var(--bg); }
  .console-bar code { font-family: var(--mono); font-size: 0.74rem; color: var(--muted); }
</style>

<!-- 表格列由 JS 動態產生,拿不到 Astro scoped 屬性,故用 is:global(以 .console 前綴避免外洩) -->
<style is:global>
  .console table { width: 100%; border-collapse: collapse; }
  .console th, .console td { text-align: left; padding: 0.65rem 0.9rem; font-size: 0.88rem; }
  .console th { font-family: var(--mono); font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); border-bottom: 1px solid var(--line); }
  .console tbody tr { border-bottom: 1px solid var(--line); }
  .console tbody tr:last-child { border-bottom: none; }
  .console tbody tr:hover { background: var(--accent-soft); }
  .console td .rank { font-family: var(--mono); color: var(--muted); }
  .console td code { font-family: var(--mono); color: var(--accent); }
  .console .bar { display: inline-block; height: 8px; min-width: 6px; border-radius: 4px; background: var(--accent); vertical-align: middle; }
  .console .muted { color: var(--muted); }
</style>

<script define:vars={{ apiUrl, txt }}>
  const $ = (id) => document.getElementById(id);

  function countTo(el, target) {
    const from = Number(el.dataset.v || 0);
    if (from === target) { el.textContent = String(target); return; }
    const start = performance.now();
    const dur = 650;
    function step(t) {
      const p = Math.min(1, (t - start) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = String(Math.round(from + (target - from) * eased));
      if (p < 1) requestAnimationFrame(step);
      else el.dataset.v = String(target);
    }
    requestAnimationFrame(step);
  }

  function renderTop(rows) {
    const top = $("top");
    if (!Array.isArray(rows) || rows.length === 0) {
      const tr = document.createElement("tr");
      const td = document.createElement("td");
      td.colSpan = 4; td.className = "muted"; td.textContent = txt.noClicks;
      tr.append(td); top.replaceChildren(tr);
      return;
    }
    const max = Math.max(...rows.map((r) => Number(r.clicks) || 0), 1);
    top.replaceChildren(...rows.map((l, i) => {
      const tr = document.createElement("tr");
      const rank = document.createElement("td");
      const rs = document.createElement("span");
      rs.className = "rank"; rs.textContent = String(i + 1).padStart(2, "0");
      rank.append(rs);
      const slug = document.createElement("td");
      const code = document.createElement("code");
      code.textContent = l.slug;
      slug.append(code);
      const clicks = document.createElement("td");
      clicks.textContent = String(l.clicks);
      const share = document.createElement("td");
      const bar = document.createElement("span");
      bar.className = "bar";
      bar.style.width = Math.max(6, (Number(l.clicks) / max) * 90) + "px";
      share.append(bar);
      tr.append(rank, slug, clicks, share);
      return tr;
    }));
  }

  const OK_MS = 15000;
  const MAX_MS = 60000;
  let delay = OK_MS;
  let timer = null;

  function schedule(ms) { clearTimeout(timer); timer = setTimeout(tick, ms); }

  async function tick() {
    try {
      const r = await fetch(`${apiUrl}/api/stats`, { signal: AbortSignal.timeout(10000) });
      if (!r.ok) throw new Error(String(r.status));
      const d = await r.json();
      countTo($("links"), Number(d.links) || 0);
      countTo($("clicks"), Number(d.clicks24h) || 0);
      renderTop(d.topLinks);
      $("live").classList.remove("off");
      $("live-text").textContent = "LIVE";
      $("sync").textContent = txt.lastSync + " · " + new Date().toLocaleTimeString();
      delay = OK_MS;
    } catch {
      $("live").classList.add("off");
      $("live-text").textContent = "OFFLINE";
      $("sync").textContent = txt.connFailed;
      delay = Math.min(delay * 2, MAX_MS);
    }
    schedule(delay);
  }

  tick();
</script>
