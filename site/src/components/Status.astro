---
import { UI, type Locale } from "../i18n/ui";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = UI[lang];
const base = lang === "en" ? "/en" : "";
// API 網域於部署時用環境變數 PUBLIC_API_URL 注入(本機留空 → 同源)。
const apiUrl = import.meta.env.PUBLIC_API_URL ?? "";
// 傳給 client script 的本地化字串。
const txt = {
  noClicks: t.st_no_clicks,
  lastSync: t.st_last_sync,
  connFailed: t.st_conn_failed,
  noVisitors: t.vs_no_visitors,
  viewsShort: t.vs_views_short,
  uniqueShort: t.vs_unique_short,
};
---

<section class="head">
  <div>
    <span class="eyebrow">{t.st_eyebrow}</span>
    <h1>{t.st_title}</h1>
    <p class="sub">{t.st_intro}</p>
    <a class="see" href={`${base}/projects/devbox`}>{t.st_see_project}</a>
  </div>
  <div class="livebox" aria-live="polite">
    <span class="live" id="live"><span class="pulse"></span><span id="live-text">LIVE</span></span>
    <span class="sync" id="sync">{t.st_syncing}</span>
  </div>
</section>

<div class="grid">
  <div class="metric">
    <span class="m-label">{t.st_short_links}</span>
    <span class="m-val" id="links" data-v="0">—</span>
    <span class="m-unit">links total</span>
  </div>
  <div class="metric accent">
    <span class="m-label">{t.st_clicks24h}</span>
    <span class="m-val" id="clicks" data-v="0">—</span>
    <span class="m-unit">clicks / 24h</span>
  </div>
  <div class="metric">
    <span class="m-label">{t.vs_views}</span>
    <span class="m-val" id="views" data-v="0">—</span>
    <span class="m-unit">page views</span>
  </div>
  <div class="metric accent">
    <span class="m-label">{t.vs_unique_today}</span>
    <span class="m-val" id="unique" data-v="0">—</span>
    <span class="m-unit">unique today</span>
  </div>
</div>

<section class="topwrap">
  <h2>{t.vs_daily}</h2>
  <div class="console">
    <div class="console-bar">
      <code>SELECT day, count() GROUP BY day ORDER BY day</code>
      <span class="legend"><i class="lg lg-v"></i>{t.vs_views_short}<i class="lg lg-u"></i>{t.vs_unique_short}</span>
    </div>
    <div id="daily" class="daychart"><span class="muted dc-msg">{t.st_querying}</span></div>
  </div>
</section>

<section class="topwrap">
  <h2>{t.st_top}</h2>
  <div class="console">
    <div class="console-bar"><code>SELECT slug, count() ORDER BY clicks DESC</code></div>
    <table>
      <thead><tr><th>#</th><th>slug</th><th>clicks</th><th>share</th></tr></thead>
      <tbody id="top"><tr><td colspan="4" class="muted">{t.st_querying}</td></tr></tbody>
    </table>
  </div>
</section>

<section class="topwrap">
  <h2>{t.vs_countries}</h2>
  <div class="console">
    <div class="console-bar"><code>SELECT country, count() GROUP BY country</code></div>
    <ul id="countries" class="ctry"><li class="muted">{t.st_querying}</li></ul>
  </div>
</section>

<style>
  .head { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap; padding: 1.6rem 0 0.5rem; }
  .head h1 { font-size: clamp(1.8rem, 6vw, 2.6rem); font-weight: 800; margin: 0.4rem 0 0.5rem; }
  .head .sub { color: var(--ink-soft); margin: 0 0 0.6rem; max-width: 54ch; font-size: 0.96rem; line-height: 1.6; }
  .see { font-family: var(--mono); font-size: 0.82rem; }
  .livebox { display: flex; flex-direction: column; align-items: flex-end; gap: 0.35rem; }
  .live { display: inline-flex; align-items: center; gap: 0.45rem; font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.06em; color: #15803d; border: 1px solid #bbf7d0; background: #f0fdf4; border-radius: 999px; padding: 0.2rem 0.6rem; }
  .live.off { color: #b91c1c; border-color: #fecaca; background: #fef2f2; }
  .live.off .pulse { background: #ef4444; animation: none; }
  .pulse { width: 7px; height: 7px; border-radius: 50%; background: #22c55e; animation: pulse 1.8s infinite; }
  @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(34,197,94,0.5);} 70% { box-shadow: 0 0 0 6px rgba(34,197,94,0);} 100% { box-shadow: 0 0 0 0 rgba(34,197,94,0);} }
  .sync { font-family: var(--mono); font-size: 0.68rem; color: var(--muted); }

  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1.5rem 0 2.5rem; }
  @media (max-width: 540px) { .grid { grid-template-columns: 1fr; } }
  .metric { position: relative; background: var(--bg-elev); border: 1px solid var(--line); border-radius: 12px; padding: 1.3rem 1.4rem; overflow: hidden; }
  .metric::after { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--line); }
  .metric.accent::after { background: var(--accent); }
  .m-label { font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.04em; color: var(--muted); }
  .m-val { display: block; font-weight: 800; font-size: clamp(2.4rem, 8vw, 3.2rem); line-height: 1.05; color: var(--ink); font-variant-numeric: tabular-nums; margin: 0.25rem 0 0.1rem; }
  .metric.accent .m-val { color: var(--accent); }
  .m-unit { font-family: var(--mono); font-size: 0.7rem; color: var(--muted); }

  .topwrap + .topwrap { margin-top: 2.6rem; }
  .topwrap h2 { font-family: var(--mono); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin: 0 0 0.7rem; }
  .console { border: 1px solid var(--line); border-radius: 12px; overflow: hidden; background: var(--bg-elev); }
  .console-bar { padding: 0.6rem 0.9rem; border-bottom: 1px solid var(--line); background: var(--bg); display: flex; align-items: center; justify-content: space-between; gap: 0.6rem; flex-wrap: wrap; }
  .console-bar code { font-family: var(--mono); font-size: 0.74rem; color: var(--muted); }
  .console-bar .legend { display: inline-flex; align-items: center; gap: 0.35rem; font-family: var(--mono); font-size: 0.66rem; color: var(--muted); }
  .console-bar .legend .lg { width: 10px; height: 10px; border-radius: 2px; display: inline-block; }
  .console-bar .legend .lg-v { background: var(--accent-soft); }
  .console-bar .legend .lg-u { background: var(--accent); margin-left: 0.5rem; }
</style>

<!-- 表格列由 JS 動態產生,拿不到 Astro scoped 屬性,故用 is:global(以 .console 前綴避免外洩) -->
<style is:global>
  .console table { width: 100%; border-collapse: collapse; }
  .console th, .console td { text-align: left; padding: 0.65rem 0.9rem; font-size: 0.88rem; }
  .console th { font-family: var(--mono); font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); border-bottom: 1px solid var(--line); }
  .console tbody tr { border-bottom: 1px solid var(--line); }
  .console tbody tr:last-child { border-bottom: none; }
  .console tbody tr:hover { background: var(--accent-soft); }
  .console td .rank { font-family: var(--mono); color: var(--muted); }
  .console td code { font-family: var(--mono); color: var(--accent); }
  .console .bar { display: inline-block; height: 8px; min-width: 6px; border-radius: 4px; background: var(--accent); vertical-align: middle; }
  .console .muted { color: var(--muted); }
  .console ul.ctry { list-style: none; margin: 0; padding: 0.4rem 0; }
  .console ul.ctry li { display: flex; align-items: center; gap: 0.7rem; padding: 0.5rem 0.9rem; border-bottom: 1px solid var(--line); }
  .console ul.ctry li:last-child { border-bottom: none; }
  .console ul.ctry .flag { width: 22px; height: 16px; border-radius: 2px; border: 1px solid var(--line); object-fit: cover; flex: 0 0 auto; background: var(--bg); }
  .console ul.ctry .cc { font-family: var(--mono); font-size: 0.8rem; color: var(--ink-soft); width: 2.2rem; }
  .console ul.ctry .cn { margin-left: auto; font-family: var(--mono); font-size: 0.82rem; color: var(--muted); font-variant-numeric: tabular-nums; }
  .console ul.ctry li.muted { color: var(--muted); justify-content: flex-start; }

  /* 每日訪客長條圖(#daily 內元素由 JS 建,需 global) */
  .daychart { display: flex; align-items: flex-end; gap: 4px; padding: 1rem 0.9rem 0.7rem; min-height: 168px; }
  .daychart .dc-msg { padding: 1.4rem 0; color: var(--muted); }
  .daychart .daycol { flex: 1 1 0; min-width: 0; display: flex; flex-direction: column; align-items: center; gap: 0.3rem; cursor: default; }
  .daychart .dc-val { font-family: var(--mono); font-size: 0.64rem; color: var(--muted); font-variant-numeric: tabular-nums; }
  .daychart .dc-track { width: 100%; height: 110px; display: flex; align-items: flex-end; justify-content: center; }
  .daychart .dc-bar { width: 64%; max-width: 26px; min-height: 2px; background: var(--accent-soft); border-radius: 3px 3px 0 0; position: relative; transition: filter 0.15s; }
  .daychart .daycol:hover .dc-bar { filter: brightness(0.94); }
  .daychart .dc-uniq { position: absolute; left: 0; right: 0; bottom: 0; background: var(--accent); border-radius: 0 0 3px 3px; }
  .daychart .dc-day { font-family: var(--mono); font-size: 0.58rem; color: var(--muted); white-space: nowrap; }
  @media (max-width: 560px) {
    .daychart { gap: 2px; }
    .daychart .dc-day { font-size: 0.5rem; transform: rotate(-45deg); transform-origin: center; margin-top: 0.2rem; }
    .daychart .dc-val { font-size: 0.56rem; }
  }
</style>

<script define:vars={{ apiUrl, txt }}>
  const $ = (id) => document.getElementById(id);

  function countTo(el, target) {
    const from = Number(el.dataset.v || 0);
    if (from === target) { el.textContent = String(target); return; }
    const start = performance.now();
    const dur = 650;
    function step(t) {
      const p = Math.min(1, (t - start) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = String(Math.round(from + (target - from) * eased));
      if (p < 1) requestAnimationFrame(step);
      else el.dataset.v = String(target);
    }
    requestAnimationFrame(step);
  }

  function renderTop(rows) {
    const top = $("top");
    if (!Array.isArray(rows) || rows.length === 0) {
      const tr = document.createElement("tr");
      const td = document.createElement("td");
      td.colSpan = 4; td.className = "muted"; td.textContent = txt.noClicks;
      tr.append(td); top.replaceChildren(tr);
      return;
    }
    const max = Math.max(...rows.map((r) => Number(r.clicks) || 0), 1);
    top.replaceChildren(...rows.map((l, i) => {
      const tr = document.createElement("tr");
      const rank = document.createElement("td");
      const rs = document.createElement("span");
      rs.className = "rank"; rs.textContent = String(i + 1).padStart(2, "0");
      rank.append(rs);
      const slug = document.createElement("td");
      const code = document.createElement("code");
      code.textContent = l.slug;
      slug.append(code);
      const clicks = document.createElement("td");
      clicks.textContent = String(l.clicks);
      const share = document.createElement("td");
      const bar = document.createElement("span");
      bar.className = "bar";
      bar.style.width = Math.max(6, (Number(l.clicks) / max) * 90) + "px";
      share.append(bar);
      tr.append(rank, slug, clicks, share);
      return tr;
    }));
  }

  // 國旗用圖片(flagcdn),避免 regional-indicator emoji 在 Windows 不顯示的問題。
  function flagEl(cc) {
    if (/^[A-Za-z]{2}$/.test(cc)) {
      const img = document.createElement("img");
      img.className = "flag"; img.loading = "lazy"; img.decoding = "async";
      img.width = 22; img.height = 16; img.alt = cc.toUpperCase();
      img.src = "https://flagcdn.com/" + cc.toLowerCase() + ".svg";
      return img;
    }
    const span = document.createElement("span");
    span.className = "flag"; span.style.border = "none"; span.style.background = "none";
    span.textContent = "🌐";
    return span;
  }
  function renderCountries(rows) {
    const box = $("countries");
    if (!Array.isArray(rows) || rows.length === 0) {
      const li = document.createElement("li");
      li.className = "muted"; li.textContent = txt.noVisitors;
      box.replaceChildren(li); return;
    }
    const max = Math.max(...rows.map((r) => Number(r.n) || 0), 1);
    box.replaceChildren(...rows.map((r) => {
      const li = document.createElement("li");
      const f = flagEl(r.country);
      const cc = document.createElement("span"); cc.className = "cc"; cc.textContent = r.country;
      const bar = document.createElement("span"); bar.className = "bar"; bar.style.width = Math.max(6, (Number(r.n) / max) * 120) + "px";
      const cn = document.createElement("span"); cn.className = "cn"; cn.textContent = String(r.n);
      li.append(f, cc, bar, cn);
      return li;
    }));
  }

  function renderDailyChart(rows) {
    const box = $("daily");
    if (!Array.isArray(rows) || rows.length === 0) {
      const s = document.createElement("span");
      s.className = "muted dc-msg"; s.textContent = txt.noVisitors;
      box.replaceChildren(s);
      return;
    }
    // API 回傳新到舊;圖表要舊到新(左→右)才符合趨勢直覺。
    const data = rows.slice().reverse();
    const max = Math.max(...data.map((r) => Number(r.views) || 0), 1);
    box.replaceChildren(...data.map((r) => {
      const views = Number(r.views) || 0;
      const uniq = Number(r.uniques) || 0;
      const col = document.createElement("div");
      col.className = "daycol";
      col.title = `${r.day} · ${views} ${txt.viewsShort} · ${uniq} ${txt.uniqueShort}`;
      const val = document.createElement("span");
      val.className = "dc-val"; val.textContent = String(views);
      const track = document.createElement("div");
      track.className = "dc-track";
      const bar = document.createElement("div");
      bar.className = "dc-bar";
      bar.style.height = (views / max) * 100 + "%";
      const u = document.createElement("div");
      u.className = "dc-uniq";
      u.style.height = views > 0 ? (uniq / views) * 100 + "%" : "0%";
      bar.append(u);
      track.append(bar);
      const lab = document.createElement("span");
      lab.className = "dc-day"; lab.textContent = r.day.slice(5); // MM-DD
      col.append(val, track, lab);
      return col;
    }));
  }

  const OK_MS = 15000;
  const MAX_MS = 60000;
  let delay = OK_MS;
  let timer = null;

  function schedule(ms) { clearTimeout(timer); timer = setTimeout(tick, ms); }

  async function tick() {
    try {
      const r = await fetch(`${apiUrl}/api/stats`, { signal: AbortSignal.timeout(25000) });
      if (!r.ok) throw new Error(String(r.status));
      const d = await r.json();
      countTo($("links"), Number(d.links) || 0);
      countTo($("clicks"), Number(d.clicks24h) || 0);
      renderTop(d.topLinks);
      countTo($("views"), Number(d.visitors?.views) || 0);
      countTo($("unique"), Number(d.visitors?.uniqueToday) || 0);
      renderCountries(d.visitors?.topCountries);
      renderDailyChart(d.visitors?.daily);
      $("live").classList.remove("off");
      $("live-text").textContent = "LIVE";
      $("sync").textContent = txt.lastSync + " · " + new Date().toLocaleTimeString();
      delay = OK_MS;
    } catch {
      $("live").classList.add("off");
      $("live-text").textContent = "OFFLINE";
      $("sync").textContent = txt.connFailed;
      delay = Math.min(delay * 2, MAX_MS);
    }
    schedule(delay);
  }

  tick();
</script>
