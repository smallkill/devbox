---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Base from "../layouts/Base.astro";
import Figure from "./Figure.astro";
import Slideshow from "./Slideshow.astro";
import ProjectCard from "./ProjectCard.astro";
import AskChat from "./AskChat.astro";
import { resolveLocalized } from "../i18n/content";
import { UI, type Locale } from "../i18n/ui";

interface Props {
  entry: CollectionEntry<"projects">;
  lang: Locale;
  slug: string;
  fallback: boolean;
}
const { entry, lang, slug, fallback } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const t = UI[lang];
const base = lang === "en" ? "/en" : "";
const meta = [d.role, d.org, d.period].filter(Boolean).join(" · ");
// SEO 描述:角色/組織/期間 + 技術棧(內文是 Markdown,不易安全截字);
// 兩者皆空時給 undefined,讓 Base 用該語言預設描述。
const seoDesc =
  [meta, d.tech.join(", ")].filter(Boolean).join(" · ") || undefined;

// 其他專案(排除目前這個),依 order 排序,給底部「更多專案」。
const allProjects = await getCollection("projects");
const others = resolveLocalized(allProjects, lang)
  .filter((p) => p.slug !== slug && p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

// resume-rag 這頁直接嵌入可互動的 /ask 問答(比放截圖更真實)。
const isAsk = slug === "resume-rag";
const projectSlugs = isAsk
  ? [...new Set(allProjects.map((e) => e.id.replace(/^(zh|en)\//, "")))]
  : [];
---

<Base
  title={`${d.title} - Derek Chen`}
  lang={lang}
  path={`/projects/${slug}`}
  description={seoDesc}
>
  <article class="proj">
    <a class="back" href={base + "/#projects"}>{t.back}</a>

    <header>
      <div class="titleline">
        <h1>{d.title}</h1>
        {fallback && <span class="fb">{t.fallback}</span>}
      </div>
      {meta && <p class="meta">{meta}</p>}
      {d.tech.length > 0 && (
        <ul class="tech">
          {d.tech.map((x) => (
            <li>{x}</li>
          ))}
        </ul>
      )}
      {d.links.length > 0 && (
        <nav class="links">
          {d.links.map((l) =>
            l.label.startsWith("Live") ? (
              <a class="live-cta" href={l.href} target="_blank" rel="noopener noreferrer">
                <span class="pulse"></span>{l.label === "Live" ? t.live_cta : l.label} ↗
              </a>
            ) : (
              <a href={l.href} target="_blank" rel="noopener noreferrer">
                {l.label} ↗
              </a>
            ),
          )}
        </nav>
      )}
    </header>

    {d.cover && (
      <div class="hero">
        <Figure src={d.cover} alt={d.title} />
      </div>
    )}

    {d.stats.length > 0 && (
      <ul class="statcards" aria-label={t.impact_stats}>
        {d.stats.map((s) => (
          <li>
            <span class="val">{s.value}</span>
            <span class="lbl">{s.label}</span>
          </li>
        ))}
      </ul>
    )}

    <div class="prose">
      <Content />
    </div>

    {isAsk && (
      <section class="livedemo">
        <h2>{t.ask_try} <span class="hint">▸ live</span></h2>
        <AskChat lang={lang} projectSlugs={projectSlugs} embedded />
      </section>
    )}

    {d.platforms.length > 0 && (
      <section class="platforms" data-tabs>
        <div class="tabbar" role="tablist">
          {d.platforms.map((p, i) => (
            <button
              class={i === 0 ? "tab on" : "tab"}
              type="button"
              data-tab={i}
              id={`tab-${slug}-${i}`}
              role="tab"
              aria-selected={i === 0 ? "true" : "false"}
              aria-controls={`panel-${slug}-${i}`}
              tabindex={i === 0 ? 0 : -1}
            >
              {p.label}
            </button>
          ))}
        </div>
        {d.platforms.map((p, i) => (
          <div
            class={i === 0 ? "panel on" : "panel"}
            data-panel={i}
            id={`panel-${slug}-${i}`}
            role="tabpanel"
            aria-labelledby={`tab-${slug}-${i}`}
            tabindex={0}
          >
            {p.caption && <p class="platform-desc">{p.caption}</p>}
            {p.image && <Figure src={p.image} alt={p.caption ?? p.label} />}
            {p.video && (
              <figure class="videowrap">
                <video controls preload="metadata" playsinline poster={p.image} aria-label={p.label} src={p.video}></video>
              </figure>
            )}
          </div>
        ))}
      </section>
    )}

    {d.slideshows.map((s) =>
      s.images.length > 0 ? (
        <Slideshow images={s.images} caption={s.caption} alt={d.title} fit={s.fit} />
      ) : null,
    )}

    {d.video && (
      <figure class="videowrap">
        <video
          controls
          preload="metadata"
          playsinline
          poster={d.cover}
          src={d.video.src}
        ></video>
        {d.video.caption && <figcaption>{d.video.caption}</figcaption>}
      </figure>
    )}

    {d.gallery.length > 0 && (
      <div class="gallery">
        {d.gallery.map((g) => (
          <Figure src={g.src} caption={g.caption} alt={d.title} />
        ))}
      </div>
    )}

    {others.length > 0 && (
      <section class="more">
        <h2>{t.more_projects} <span class="hint">←→</span></h2>
        <div class="more-row">
          {others.map((p) => (
            <ProjectCard
              href={`${base}/projects/${p.slug}`}
              title={p.data.title}
              role={p.data.role}
              period={p.data.period}
              tech={p.data.tech}
              cover={p.data.cover}
              fallbackLabel={p.fallback ? t.fallback : undefined}
            />
          ))}
        </div>
      </section>
    )}
  </article>

  <script>
    // platform tabs: switch screenshot+video panels; pause hidden videos.
    // Implements the WAI-ARIA tabs pattern: roving tabindex + arrow/Home/End keys.
    document.querySelectorAll("[data-tabs]").forEach((root) => {
      const tabs = Array.from(root.querySelectorAll<HTMLElement>("[data-tab]"));
      const panels = Array.from(root.querySelectorAll<HTMLElement>("[data-panel]"));

      const activate = (tab: HTMLElement, focus = false) => {
        const i = tab.getAttribute("data-tab");
        tabs.forEach((t) => {
          const on = t === tab;
          t.classList.toggle("on", on);
          t.setAttribute("aria-selected", on ? "true" : "false");
          t.tabIndex = on ? 0 : -1;
        });
        panels.forEach((p) => {
          const on = p.getAttribute("data-panel") === i;
          p.classList.toggle("on", on);
          if (!on) {
            const v = p.querySelector("video");
            if (v) v.pause();
          }
        });
        if (focus) tab.focus();
      };

      tabs.forEach((tab, idx) => {
        tab.addEventListener("click", () => activate(tab));
        tab.addEventListener("keydown", (e) => {
          let next = -1;
          if (e.key === "ArrowRight") next = (idx + 1) % tabs.length;
          else if (e.key === "ArrowLeft") next = (idx - 1 + tabs.length) % tabs.length;
          else if (e.key === "Home") next = 0;
          else if (e.key === "End") next = tabs.length - 1;
          if (next >= 0) {
            e.preventDefault();
            activate(tabs[next], true);
          }
        });
      });
    });
  </script>

  <style>
    .proj { padding: 1.5rem 0 1rem; }
    .back { font-family: var(--mono); font-size: 0.8rem; color: var(--muted); }
    .back:hover { color: var(--accent); text-decoration: none; }
    .titleline { display: flex; align-items: baseline; gap: 0.7rem; margin-top: 1rem; }
    h1 { font-size: clamp(1.8rem, 6vw, 2.6rem); font-weight: 800; margin: 0; }
    .fb {
      font-family: var(--mono); font-size: 0.65rem; color: var(--muted);
      border: 1px solid var(--line); border-radius: 4px; padding: 0.1rem 0.4rem;
    }
    .meta { color: var(--muted); margin: 0.4rem 0 0.8rem; }
    .tech { list-style: none; padding: 0; margin: 0 0 0.9rem; display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .tech li {
      font-family: var(--mono); font-size: 0.72rem; color: var(--ink-soft);
      background: var(--bg-elev); border: 1px solid var(--line);
      border-radius: 5px; padding: 0.15rem 0.5rem;
    }
    .links { display: flex; flex-wrap: wrap; align-items: center; gap: 1.1rem; font-family: var(--mono); font-size: 0.85rem; margin-bottom: 1rem; }
    /* Live 連結:醒目綠色按鈕 + 脈動點,讓人一看就知可點進線上專案 */
    .live-cta {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: #15803d; color: #fff; border-radius: 999px;
      padding: 0.4rem 0.95rem; font-weight: 700; text-decoration: none;
      box-shadow: 0 6px 18px -10px rgba(21, 128, 61, 0.7);
    }
    .live-cta:hover { background: #166534; text-decoration: none; }
    .live-cta .pulse { width: 8px; height: 8px; border-radius: 50%; background: #86efac; animation: livepulse 1.8s infinite; }
    @keyframes livepulse { 0% { box-shadow: 0 0 0 0 rgba(134,239,172,0.7);} 70% { box-shadow: 0 0 0 7px rgba(134,239,172,0);} 100% { box-shadow: 0 0 0 0 rgba(134,239,172,0);} }
    @media (prefers-reduced-motion: reduce) { .live-cta .pulse { animation: none; } }
    .prose { font-size: 1.02rem; color: var(--ink-soft); border-top: 1px solid var(--line); padding-top: 1.4rem; }
    .prose :global(p) { margin: 0 0 1rem; }
    .prose :global(ul) { margin: 0 0 1rem; padding-left: 1.2rem; }
    .prose :global(li) { margin: 0.3rem 0; }
    .prose :global(li::marker) { color: var(--accent); }
    .prose :global(strong) { color: var(--ink); font-weight: 700; }
    .prose :global(code) {
      font-family: var(--mono); font-size: 0.86em;
      background: var(--bg-elev); border: 1px solid var(--line);
      border-radius: 4px; padding: 0.05rem 0.35rem;
    }
    .gallery { margin-top: 1rem; }

    /* Impact 數字卡:把埋在內文的硬事實抽到 hero 下方,招募方一眼掃到。
       自適應網格、用站上輕色系與等寬字,桌機一排、手機自動收成 2 欄。 */
    .statcards {
      list-style: none;
      margin: 1.4rem 0 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 0.7rem;
    }
    .statcards li {
      background: var(--bg-elev);
      border: 1px solid var(--line);
      border-left: 3px solid var(--accent);
      border-radius: 9px;
      padding: 0.85rem 0.95rem;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .statcards .val {
      font-family: var(--mono);
      font-size: 1.05rem;
      font-weight: 700;
      line-height: 1.25;
      color: var(--ink);
    }
    .statcards .lbl {
      font-size: 0.78rem;
      line-height: 1.45;
      color: var(--muted);
    }
    @media (max-width: 560px) {
      .statcards { grid-template-columns: 1fr 1fr; }
    }

    /* 示範影片(頁面下方) */
    .videowrap { margin: 1.6rem 0 0; }
    .videowrap video {
      width: 100%; display: block; border-radius: 10px;
      border: 1px solid var(--line); background: #000;
    }
    .videowrap figcaption {
      font-family: var(--mono); font-size: 0.78rem; color: var(--muted);
      margin-top: 0.5rem; line-height: 1.5;
    }

    /* 多平台 tab demo */
    .platforms { margin: 1.8rem 0 0; }
    .tabbar {
      display: flex; flex-wrap: wrap; gap: 0.4rem;
      border-bottom: 1px solid var(--line); margin-bottom: 1.1rem;
    }
    .tab {
      font-family: var(--mono); font-size: 0.8rem; color: var(--muted);
      background: transparent; border: 1px solid transparent; border-bottom: none;
      border-radius: 7px 7px 0 0; padding: 0.45rem 0.9rem; cursor: pointer;
      margin-bottom: -1px; line-height: 1.45;
    }
    .tab:hover { color: var(--ink); }
    .tab.on {
      color: var(--accent); font-weight: 700;
      background: var(--bg-elev); border-color: var(--line);
      border-bottom-color: var(--bg-elev);
    }
    .platforms .panel { display: none; }
    .platforms .panel.on { display: block; }
    .platform-desc {
      font-size: 0.96rem; color: var(--ink-soft); line-height: 1.6;
      margin: 0 0 1.1rem; max-width: 70ch;
    }
    .platforms .videowrap { margin-top: 1.1rem; }

    /* resume-rag 內嵌的 live 問答 */
    .livedemo {
      margin-top: 2rem;
      border-top: 1px solid var(--line);
      padding-top: 1.2rem;
    }
    .livedemo > h2 {
      font-family: var(--mono); font-size: 0.9rem; text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--muted); margin: 0 0 0.4rem;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .livedemo > h2 .hint {
      color: var(--accent); font-size: 0.75rem; letter-spacing: 0;
      text-transform: none;
    }

    /* 更多專案:獨立區塊 + 橫向滑動 strip */
    .more {
      margin-top: 3.5rem;
      border-top: 2px solid var(--line);
      padding-top: 1.4rem;
    }
    .more h2 {
      font-family: var(--mono); font-size: 0.9rem; text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--muted); margin: 0 0 1rem;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .more h2 .hint { color: var(--accent); font-size: 0.8rem; letter-spacing: 0; }
    .more-row {
      display: flex;
      gap: 0.9rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 0.7rem;
      scrollbar-width: thin;
    }
    .more-row > :global(a) {
      flex: 0 0 248px;
      scroll-snap-align: start;
    }
    .more-row::-webkit-scrollbar { height: 6px; }
    .more-row::-webkit-scrollbar-thumb { background: var(--line); border-radius: 3px; }
  </style>
</Base>
